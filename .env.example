# ----------------------------------------------------------------------------
# Rewilding Speech Therapy — environment variables
# Copy to .env.local (git-ignored) and fill in. The site renders from typed
# fallback content when Sanity vars are absent, so these are optional for local
# dev but required for live, editable content + the contact form.
# ----------------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="https://rewildingspeech.com"

# --- Sanity (content) ---
# Create a free project at https://sanity.io, then fill these in.
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"
# Write token (Editor) — ONLY used by the seed script, never shipped to the client.
SANITY_API_TOKEN=""

# --- Resend (contact form email) ---
# Get an API key at https://resend.com (free tier: 3k emails/mo).
RESEND_API_KEY=""
# Where contact submissions are delivered:
CONTACT_TO_EMAIL="hello@rewildingspeech.com"
# Verified sender (must be a domain/address verified in Resend):
CONTACT_FROM_EMAIL="Rewilding Speech <noreply@rewildingspeech.com>"

# --- Cloudflare Turnstile (contact-form bot protection) ---
# REQUIRED IN PRODUCTION (fail-closed): if unset in prod, /api/contact returns 503 and sends
# nothing. Skipped only in local dev. Create a widget at Cloudflare → Turnstile (you're already
# on Cloudflare). The widget renders when the site key is set; the secret verifies server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
