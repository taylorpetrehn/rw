# 1Password secret references for RW local dev (apps/web).
# Safe to commit — these are op:// references, not values.
# Run via: opr run --env-file=op.env -- pnpm dev   (or any command needing env)
# Values live in vault Rewilding-Dev, item "Web Environment".
NEXT_PUBLIC_SANITY_PROJECT_ID="op://Rewilding-Dev/Web Environment/NEXT_PUBLIC_SANITY_PROJECT_ID"
NEXT_PUBLIC_SANITY_DATASET="op://Rewilding-Dev/Web Environment/NEXT_PUBLIC_SANITY_DATASET"
NEXT_PUBLIC_SANITY_API_VERSION="op://Rewilding-Dev/Web Environment/NEXT_PUBLIC_SANITY_API_VERSION"
NEXT_PUBLIC_SITE_URL="op://Rewilding-Dev/Web Environment/NEXT_PUBLIC_SITE_URL"
# Server-only secrets — not yet in 1Password (dev runs without them by design).
# When needed (seeding / contact form), add the field to the Web Environment
# item, then uncomment:
# SANITY_API_TOKEN="op://Rewilding-Dev/Web Environment/SANITY_API_TOKEN"
# RESEND_API_KEY="op://Rewilding-Dev/Web Environment/RESEND_API_KEY"
# TURNSTILE_SECRET_KEY="op://Rewilding-Dev/Web Environment/TURNSTILE_SECRET_KEY"
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="op://Rewilding-Dev/Web Environment/NEXT_PUBLIC_TURNSTILE_SITE_KEY"
